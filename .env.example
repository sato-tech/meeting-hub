# ═══════════════════════════════════════════════════════════════
# meeting-hub 環境変数テンプレート
# ─ 実キーは .env に設定し、.env は .gitignore 対象
# ═══════════════════════════════════════════════════════════════

# ─── Hugging Face（pyannote モデル DL に必須）───
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Anthropic Claude ───
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Drive（サービスアカウント、§12-5 RESOLVED）───
# GCP プロジェクトで Drive API 有効化 → SA 作成 → JSON 鍵を配置 → Drive 対象フォルダを SA メールで閲覧者共有
GOOGLE_APPLICATION_CREDENTIALS=./secrets/sa.json

# ─── Notion（Phase 2+ で実装）───
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_SALES=
NOTION_DB_INTERNAL=
NOTION_DB_SEMINAR=
NOTION_DB_RECRUITING=

# ─── Slack（Phase 2 実装）───
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Gmail SMTP（Phase 2 実装、app password 利用）───
# 取得方法: Google アカウント → セキュリティ → 2段階認証 → アプリパスワード
GMAIL_USER=your.name@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── ロギング ───
LOG_LEVEL=INFO
